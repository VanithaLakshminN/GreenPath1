# Instagram Basic Display API Configuration
# Get these values from Facebook Developer Console → Your App → Instagram Basic Display → Basic Display
# https://developers.facebook.com/apps/

# Instagram App ID (from Instagram Basic Display, NOT Facebook Login)
VITE_INSTAGRAM_CLIENT_ID=your_instagram_client_id_here

# Instagram App Secret (from Instagram Basic Display, NOT Facebook Login)
VITE_INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret_here
# Instagram OAuth Redirect URI
# This should match the redirect URI configured in your Instagram Basic Display app
# For development: http://localhost:5174/auth/instagram/callback
# For production: https://yourdomain.com/auth/instagram/callback
VITE_INSTAGRAM_REDIRECT_URI=http://localhost:5173/auth/instagram/callback


# Firebase Configuration (existing)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# Google Maps API Configuration (existing)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here